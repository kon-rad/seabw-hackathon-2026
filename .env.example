# Together AI (required)
TOGETHER_AI_API_KEY=your_together_ai_key_here

# Neo4j Aura Free (required)
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_PASSWORD=your_neo4j_password_here

# Polymarket - funded Polygon wallet with USDC (required for bet placement)
POLYMARKET_PRIVATE_KEY=your_polygon_wallet_private_key_here

# Optional: MiroShark admin token for mutation endpoints
MIROSHARK_ADMIN_TOKEN=change_me_in_production
