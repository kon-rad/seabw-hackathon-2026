# ============================================================
# Together AI configuration for MiroShark Polymarket Platform
# Copy this to web/.env and fill in your keys.
# ============================================================

# ===== Together AI (all LLM calls) =====
LLM_PROVIDER=openai
LLM_API_KEY=                          # ← paste your Together AI key
LLM_BASE_URL=https://api.together.xyz/v1
LLM_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct-Turbo

# Smart model — same key/base, slightly better model for reports
SMART_PROVIDER=openai
SMART_API_KEY=                        # ← same Together AI key
SMART_BASE_URL=https://api.together.xyz/v1
SMART_MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct-Turbo

# NER (entity extraction)
NER_API_KEY=                          # ← same Together AI key
NER_BASE_URL=https://api.together.xyz/v1
NER_MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Wonderwall agent simulation — cheapest model (most calls)
WONDERWALL_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct-Turbo
WONDERWALL_BASE_URL=https://api.together.xyz/v1
WONDERWALL_API_KEY=                   # ← same Together AI key

# CAMEL-AI / Wonderwall internal (must match)
OPENAI_API_KEY=                       # ← same Together AI key
OPENAI_API_BASE_URL=https://api.together.xyz/v1

# Research agent (free tier — no cost)
RESEARCH_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# ===== Embeddings via Together AI =====
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_BASE_URL=https://api.together.xyz/v1
EMBEDDING_API_KEY=                    # ← same Together AI key
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=32

# ===== Neo4j Aura Free =====
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=                       # ← your Aura password

# ===== Polymarket =====
POLYMARKET_PRIVATE_KEY=               # ← Polygon wallet private key (funded with USDC)

# ===== Memory optimisations for 2GB VPS =====
RERANKER_ENABLED=false
COMMUNITY_MIN_SIZE=5
COMMUNITY_MAX_COUNT=10

# ===== Admin =====
MIROSHARK_ADMIN_TOKEN=                # ← generate: openssl rand -hex 32

# ===== Misc =====
LLM_DISABLE_REASONING=true
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
ENABLE_SITEMAP=false
